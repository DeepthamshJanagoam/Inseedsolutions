{
  "version": 2,
  "installCommand": "cd backend && npm ci",
  "buildCommand": "cd backend && npm run prisma:generate",
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/$1"
    }
  ]
}
